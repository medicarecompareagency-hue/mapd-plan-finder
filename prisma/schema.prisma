// MAPD Plan Finder - Prisma Database Schema
// Copy this file into your project at: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlanCategory {
  MA_ONLY
  MAPD
  PDP
  DSNP
  CSNP
  ISNP
  MSA
  PACE
  COST
  MMP
  OTHER
}

enum SnpSubtype {
  ISNP_FACILITY
  ISNP_EQUIVALENT
  ISNP_HYBRID
  DSNP_FBDE
  DSNP_QMB_PLUS
  DSNP_QMB
  DSNP_SLMB_PLUS
  DSNP_SLMB
  DSNP_QI
  DSNP_MEDICAID_ONLY
}

enum ChronicCondition {
  ALCOHOL_SUD
  AUTOIMMUNE
  CANCER
  CARDIOVASCULAR
  CHRONIC_HEART_FAILURE
  DEMENTIA
  DIABETES
  GASTROINTESTINAL
  CHRONIC_KIDNEY_DISEASE
  HEMATOLOGIC
  HIV_AIDS
  LUNG_DISORDERS
  MENTAL_HEALTH
  NEUROLOGIC
  STROKE
  CHF_AND_CVD
  DIABETES_AND_CVD
  CHF_AND_DIABETES
  DIABETES_CHF_CVD
  STROKE_AND_CVD
  METABOLIC_SYNDROME
  POST_TRANSPLANT
  IMMUNODEFICIENCY
  COGNITIVE_IMPAIRMENT
  FUNCTIONAL_CHALLENGES
  SENSORY_IMPAIRMENT
  THERAPY_MAINTENANCE
  ANXIETY_WITH_COPD
  CKD_AND_TRANSPLANT
  SUD_AND_MH
  OTHER_1
  OTHER_2
  OTHER_3
}

model Plan {
  id                        Int      @id @default(autoincrement())
  planYear                  Int
  planId                    String
  planName                  String
  organizationName          String
  planType                  String
  planCategory              PlanCategory?
  snpSubtype                SnpSubtype?
  chronicConditions         ChronicCondition[] @default([])
  hasPartD                  Boolean?
  isZeroDollarDsnp          Boolean?
  cmsContractType           String?
  state                     String
  county                    String
  zipCode                   String?
  monthlyPremium            Float
  partBGivebackAmount       Float?   @default(0)
  lowIncomeSubsidyLevel     String?
  medicaidLevel             String?
  medicalDeductible         Float?   @default(0)
  maxOutOfPocket            Float?
  pcpCopay                  Float?
  specialistCopay           Float?
  emergencyRoomCopay        Float?
  ambulanceCopay            Float?
  outpatientHospitalCopay   Float?
  hospitalStayCopay         String?
  skilledNursingCopay       String?
  mriCopay                  Float?
  catScanCopay              Float?
  pcpCoinsPct                 Float?
  specialistCoinsPct          Float?
  emergencyRoomCoinsPct       Float?
  ambulanceCoinsPct           Float?
  outpatientHospitalCoinsPct  Float?
  mriCoinsPct                 Float?
  catScanCoinsPct             Float?
  drugDeductible            Float?   @default(0)
  drugTier1Copay            Float?
  drugTier2Copay            Float?
  drugTier3Copay            Float?
  drugTier4Copay            Float?
  drugTier5Copay            Float?
  drugTier6Copay            Float?
  drugTierCoinsuranceMask String?
  otcAllowance              Float?   @default(0)
  otcMaxPeriod              String?
  foodCardAllowance         Float?   @default(0)
  dentalAnnualMax           Float?   @default(0)
  visionAnnualMax           Float?   @default(0)
  hearingAnnualMax          Float?   @default(0)
  dentalBenefits            String?
  hearingBenefits           String?
  visionBenefits            String?
  transportationBenefit     String?
  ssbciOffersFood           Boolean? @default(false)
  ssbciOffersMeals          Boolean? @default(false)
  ssbciOffersUtilities      Boolean? @default(false)
  ssbciOffersHousing        Boolean? @default(false)
  ssbciOffersTransportation Boolean? @default(false)
  ssbciFoodAllowance              Float?
  ssbciMealsAllowance             Float?
  ssbciPersonalServicesAllowance  Float?
  ssbciTransportationAllowance    Float?

  sbPdfUrl                  String?
  sbPdfChecksum             String?
  sbPdfSourceFilename       String?
  sbDiscoveryConfidence     Float?
  sbLastProcessedAt         DateTime?

  sbOtcPage                 Int?
  sbFoodCardPage            Int?
  sbDentalPage              Int?
  sbVisionPage              Int?
  sbHearingPage             Int?
  sbTransportationPage      Int?

  sbVerifiedOtcAmount       Float?
  sbVerifiedFoodAmount      Float?

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  starRating                Float?

  dsnpTargetGroup           DsnpTargetGroup?

  @@index([state, county])
  @@index([planYear])
  @@index([monthlyPremium])
  @@index([planId])
  @@index([planCategory])
  @@index([state, county, planCategory])
}

model GeoLocation {
  id      Int    @id @default(autoincrement())
  state   String
  county  String
  zipCode String

  @@index([state])
  @@index([state, county])
  @@unique([state, county, zipCode])
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  name          String?
  passwordHash  String
  role          String    @default("agent")
  createdAt       DateTime        @default(now())
  searches        Search[]
  passwordResets  PasswordReset[]
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model Search {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  searchName  String?
  filters     Json
  createdAt   DateTime @default(now())
}

enum DsnpTargetGroup {
  FULL_DUAL
  PARTIAL_DUAL
}
